{
  "manifest_version": 3,
  "name": "Netflix Episode Shuffle",
  "version": "2.0",
  "description": "Randomly shuffles episodes across all available seasons with a loading spinner.",
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.netflix.com/*",
        "*://www.netflix.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}